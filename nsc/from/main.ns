function main() {
}

class User {
  id: string
  name: string

  constructor(id: string, name: string) {
    this.id = id
    this.name = name
  }
} 

enum Role {
  Admin,
  Customer,
  Seller,

  toString(&this): String {
    return match this {
      Admin => "Admin",
      Customer => "Customer",
      Seller => "Seller",
    }
  }
}

